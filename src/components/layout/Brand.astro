---
import site from "@/config/site";
---

<div
  class="mb-6 flex items-center gap-4 md:mb-10 md:flex-col md:items-start md:gap-0"
>
  <div class="md:mt-8">
    <h1 class="text-lg font-bold tracking-tight text-foreground md:text-xl">
      {site.meta.title}
    </h1>
    <p class="mt-2 hidden text-xs text-muted-foreground/70 md:block">
      {site.meta.description}
    </p>
  </div>
</div>
