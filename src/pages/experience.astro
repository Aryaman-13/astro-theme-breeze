---
import Layout from "@/layouts/Layout.astro";
import site from "@/config/site";
import { getCollection } from "astro:content";

const work = (await getCollection("experienceWork")).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime(),
);
---

<Layout
  title={site.labels.experienceTitle}
  description={site.labels.experienceDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        {site.labels.experienceTitle}
      </h2>
      <p class="text-sm font-light text-muted-foreground italic">
        {site.labels.experienceDescription}
      </p>
    </header>

    <!-- Work Section -->
    <section class="mb-16">
      <h3
        class="mb-8 text-sm font-semibold tracking-widest text-foreground/70 uppercase"
      >
        {site.labels.experienceWorkTitle}
      </h3>

      <div class="relative">
        <!-- Vertical line -->
        <div
          class="absolute top-2 bottom-2 left-3 w-px bg-gradient-to-b from-primary/40 via-primary/20 to-transparent"
        >
        </div>

        <div class="space-y-6">
          {
            work.map((entry, i) => (
              <div
                class="group relative flex gap-6 pl-10"
                style={`animation-delay: ${i * 100}ms`}
              >
                {/* <!-- Dot --> */}
                <div class="absolute top-4 left-0 flex h-6 w-6 shrink-0 items-center justify-center">
                  <div class="h-2.5 w-2.5 rounded-full border-2 border-primary/60 bg-background transition-all duration-300 group-hover:border-primary group-hover:bg-primary/20" />
                </div>

                {/* <!-- Card --> */}
                <div class="w-full rounded-2xl border border-border/50 bg-card/10 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-muted/40 hover:shadow-lg">
                  <div class="mb-3 flex items-start justify-between gap-2">
                    <div class="min-w-0">
                      <h4 class="text-sm font-bold tracking-wide">
                        {entry.data.role}
                      </h4>
                      <p class="mt-0.5 text-xs text-muted-foreground">
                        {entry.data.company}
                        {entry.data.location && (
                          <span class="before:mx-1.5 before:content-['·']">
                            {entry.data.location}
                          </span>
                        )}
                      </p>
                    </div>
                    <div class="flex shrink-0 flex-col items-end gap-1">
                      <span class="rounded-full border border-primary/20 bg-primary/10 px-2 py-0.5 text-[10px] font-bold tracking-widest text-primary">
                        {entry.data.period}
                      </span>
                      {entry.data.type && (
                        <span class="text-[10px] tracking-widest text-foreground/90 uppercase">
                          {entry.data.type}
                        </span>
                      )}
                    </div>
                  </div>

                  {entry.data.description && (
                    <p class="mb-3 text-xs leading-relaxed text-muted-foreground">
                      {entry.data.description}
                    </p>
                  )}

                  {entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {entry.data.tags.map((tag) => (
                        <span class="font-mono text-[10px] text-primary/50">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>
