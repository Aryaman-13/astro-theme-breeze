---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import site from "@/config/site";
import { Icon } from "astro-icon/components";

const projects = await getCollection("projects");
---

<Layout
  title={site.labels.projectsTitle}
  description={site.labels.projectsDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        {site.labels.projectsTitle}
      </h2>
      <p class="text-sm font-light text-muted-foreground italic">
        {site.labels.projectsDescription}
      </p>
    </header>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        projects.length === 0 ? (
          <div class="col-span-full py-12 text-center">
            <p class="text-sm text-muted-foreground">No projects yet.</p>
          </div>
        ) : (
          projects.map((project) => (
            <div class="group flex h-full flex-col rounded-2xl border border-border/50 bg-card/10 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:bg-muted/40 hover:shadow-lg">
              <div class="mb-4 flex items-start justify-between">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/15 text-primary transition-all duration-300 group-hover:bg-primary/25">
                  {project.data.image ? (
                    <Image
                      src={project.data.image}
                      width={28}
                      height={28}
                      alt={`${project.data.title}'s logo'`}
                      loading={"lazy"}
                    />
                  ) : (
                    <span class="text-sm">✦</span>
                  )}
                </div>
                <span class="rounded-full border border-primary/20 bg-primary/10 px-2 py-0.5 text-[9px] font-bold tracking-widest text-primary uppercase">
                  {project.data.status}
                </span>
              </div>
              <h3 class="mb-2 text-base font-bold tracking-widest">
                {project.data.title}
              </h3>
              <p class="project-desc mb-1 line-clamp-2 text-xs leading-relaxed tracking-widest text-muted-foreground">
                {project.data.description}
              </p>
              <button
                class="project-toggle mb-3 self-start text-[11px] font-bold tracking-widest text-primary/70 transition-colors duration-200 hover:text-primary"
                aria-expanded="false"
              >
                Show more
              </button>
              <div class="mb-3 flex flex-wrap gap-2">
                {project.data.tech.map((t) => (
                  <span class="font-mono text-[10px] text-primary/50">
                    #{t}
                  </span>
                ))}
              </div>
              {project.data.links && (
                <div class="flex gap-2">
                  {project.data.links.homepage && (
                    <a
                      href={project.data.links.homepage}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1 rounded-lg border border-border/50 bg-muted/30 px-3 py-2 text-[11px] font-medium text-foreground/70 hover:border-primary/40 hover:text-primary"
                    >
                      <Icon name="mdi:web" class="h-3 w-3" />
                      Website
                    </a>
                  )}
                  {project.data.links.github && (
                    <a
                      href={project.data.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1 rounded-lg border border-border/50 bg-muted/30 px-3 py-2 text-[11px] font-medium text-foreground/70 hover:border-primary/40 hover:text-primary"
                    >
                      <Icon name="mdi:github" class="h-5 w-5" />
                    </a>
                  )}
                  {project.data.links.demo && (
                    <a
                      href={project.data.links.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1 rounded-lg border border-border/50 bg-muted/30 px-3 py-2 text-[11px] font-medium text-foreground/70 hover:border-primary/40 hover:text-primary"
                    >
                      <Icon name="mdi:open-in-new" class="h-3 w-3" />
                      Demo
                    </a>
                  )}
                </div>
              )}
            </div>
          ))
        )
      }
    </div>
  </div>
  <script>
    function setupToggles() {
      document
        .querySelectorAll<HTMLButtonElement>(".project-toggle")
        .forEach((btn) => {
          const desc = btn.previousElementSibling as HTMLElement;
          if (desc.scrollHeight <= desc.clientHeight) {
            btn.style.display = "none";
            return;
          }
          btn.addEventListener("click", () => {
            const expanded = btn.getAttribute("aria-expanded") === "true";
            if (expanded) {
              desc.classList.add("line-clamp-2");
              btn.setAttribute("aria-expanded", "false");
              btn.textContent = "Show more";
            } else {
              desc.classList.remove("line-clamp-2");
              btn.setAttribute("aria-expanded", "true");
              btn.textContent = "Show less";
            }
          });
        });
    }

    document.addEventListener("astro:page-load", setupToggles);
  </script>
</Layout>
