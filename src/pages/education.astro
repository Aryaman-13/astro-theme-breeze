---
import Layout from "@/layouts/Layout.astro";
import site from "@/config/site";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const timeline = await getCollection("educationTimeline");
const courses = await getCollection("educationCourses");
---

<Layout
  title={site.labels.educationTitle}
  description={site.labels.educationDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        {site.labels.educationTitle}
      </h2>
      <p class="text-sm font-light text-muted-foreground italic">
        {site.labels.educationDescription}
      </p>
    </header>

    <!-- Timeline Section -->
    <section class="mb-16">
      <h3 class="mb-8 text-xs font-bold tracking-widest text-primary uppercase">
        {site.labels.educationTimelineTitle}
      </h3>

      <div class="relative">
        <!-- Vertical line -->
        <div
          class="absolute top-2 bottom-2 left-3 w-px bg-gradient-to-b from-primary/40 via-primary/20 to-transparent"
        >
        </div>

        <div class="space-y-6">
          {
            timeline.map((entry, i) => (
              <div
                class="group relative flex gap-6 pl-10"
                style={`animation-delay: ${i * 100}ms`}
              >
                {/* <!-- Dot on the line --> */}
                <div class="absolute top-4 left-0 flex h-6 w-6 shrink-0 items-center justify-center">
                  <div class="h-2.5 w-2.5 rounded-full border-2 border-primary/60 bg-background transition-all duration-300 group-hover:border-primary group-hover:bg-primary/20" />
                </div>

                {/* <!-- Card --> */}
                <div class="w-full rounded-2xl border border-border/50 bg-muted/20 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-muted/40 hover:shadow-lg">
                  <div class="mb-3 flex items-start justify-between gap-2">
                    <div class="min-w-0">
                      <h4 class="text-sm font-bold tracking-wider">
                        {entry.data.degree}
                      </h4>
                      <p class="mt-0.5 text-xs text-muted-foreground">
                        {entry.data.institution}
                      </p>
                    </div>
                    <div class="flex shrink-0 flex-col items-end gap-1">
                      <span class="rounded-full border border-primary/20 bg-primary/10 px-2 py-0.5 text-[10px] font-bold tracking-widest text-primary">
                        {entry.data.period}
                      </span>
                      {entry.data.gpa && (
                        <span class="text-[10px] tracking-widest text-muted-foreground/70 uppercase">
                          {entry.data.gpa}
                        </span>
                      )}
                    </div>
                  </div>

                  {entry.data.description && (
                    <p class="mb-3 text-xs leading-relaxed text-muted-foreground">
                      {entry.data.description}
                    </p>
                  )}

                  {entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {entry.data.tags.map((tag) => (
                        <span class="font-mono text-[10px] text-primary/50">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Courses Section -->
    <section>
      <h3 class="mb-8 text-xs font-bold tracking-widest text-primary uppercase">
        {site.labels.educationCoursesTitle}
      </h3>

      <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
        {
          courses.map((course, i) =>
            course.data.link ? (
              <a
                href={course.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-3.5 rounded-2xl border border-border/50 bg-muted/20 p-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-muted/40 hover:shadow-md"
                style={`animation-delay: ${i * 80}ms`}
              >
                {/* <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary/60 transition-all duration-300 group-hover:bg-primary/20 group-hover:text-primary">
                  <Icon
                    name={course.data.icon ?? "mdi:certificate-outline"}
                    class="h-4 w-4"
                  />
                </div> */}
                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-xs font-bold tracking-widest text-foreground/90 transition-colors duration-300 group-hover:text-primary">
                      {course.data.name}
                    </p>
                    <Icon
                      name="mdi:open-in-new"
                      class="mt-0.5 h-3 w-3 shrink-0 text-muted-foreground/40 transition-colors duration-300 group-hover:text-primary/60"
                    />
                  </div>
                  <p class="mt-0.5 text-[10px] tracking-widest text-muted-foreground/70">
                    {course.data.provider}
                  </p>
                  <span class="mt-1.5 inline-block rounded-full border border-border/40 bg-muted/30 px-1.5 py-0.5 text-[9px] font-bold tracking-widest text-muted-foreground/60 uppercase">
                    {course.data.year}
                  </span>
                </div>
              </a>
            ) : (
              <div
                class="flex items-start gap-3.5 rounded-2xl border border-border/50 bg-muted/20 p-4"
                style={`animation-delay: ${i * 80}ms`}
              >
                <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary/60">
                  <Icon
                    name={course.data.icon ?? "mdi:certificate-outline"}
                    class="h-4 w-4"
                  />
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-xs font-bold tracking-widest text-foreground/90">
                    {course.data.name}
                  </p>
                  <p class="mt-0.5 text-[10px] tracking-widest text-muted-foreground/70">
                    {course.data.provider}
                  </p>
                  <span class="mt-1.5 inline-block rounded-full border border-border/40 bg-muted/30 px-1.5 py-0.5 text-[9px] font-bold tracking-widest text-muted-foreground/60 uppercase">
                    {course.data.year}
                  </span>
                </div>
              </div>
            ),
          )
        }
      </div>
    </section>
  </div>
</Layout>
